# Source files (not needed in package, only compiled dist)
src/
**/*.ts
**/*.tsx
!src/**/*.d.ts

# Tests
tests/
test/
**/*.test.ts
**/*.spec.ts

# Examples (not needed in package, see GitHub for examples)
examples/

# Development files
.eslintrc.cjs
.prettierrc.json
*.config.ts
*.config.js
tsconfig*.json
tsxconfig.json

# Build output (included via "files" field, but exclude intermediate)
dist/**/*.map
dist/**/*.d.ts.map

# Documentation (keep README.md, SUMMARY.md optional)
CHANGELOG.md
CONTRIBUTING.md
docs/

# CI/CD
.github/
.gitlab-ci.yml
.gitignore

# Misc
.cache/
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log
