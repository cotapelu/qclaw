{
  "name": "@mariozechner/pi-tui-professional",
  "version": "1.0.0",
  "description": "Professional TUI components for building terminal-based AI coding assistants. Built on @mariozechner/pi-tui and @mariozechner/pi-coding-agent.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/qcoder/qclaw.git",
    "directory": "packages/tui"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "prepack": "npm run build && npm test && npm pack --dry-run",
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:unit && npm run test:comprehensive && npm run test:integration",
    "test:all": "npm test && npm run test:sanity",
    "test:unit": "tsx tests/run.test.ts",
    "test:comprehensive": "tsx tests/comprehensive.test.ts",
    "test:integration": "tsx tests/integration.test.ts",
    "test:sanity": "tsx tests/agent-session-sanity.test.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.68.0",
    "@mariozechner/pi-tui": "^0.68.0",
    "@mariozechner/pi-agent-core": "^0.68.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-tui": "^0.68.0",
    "@mariozechner/pi-coding-agent": "^0.68.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "QUICKSTART.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "COMPATIBILITY.md",
    "TROUBLESHOOTING.md",
    "ROADMAP.md",
    "DEPLOYMENT.md",
    "OPTIONAL_IMPROVEMENTS.md",
    "PRODUCTION_READINESS.md"
  ],
  "keywords": [
    "tui",
    "terminal",
    "cli",
    "coding-agent",
    "ai",
    "assistant",
    "chat",
    "llm",
    "gpt",
    "claude",
    "anthropic",
    "openai",
    "terminal-ui",
    "curses",
    "interactive"
  ],
  "author": "Qcoder Team",
  "license": "Apache-2.0"
}
