{
  "name": "piclaw",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Pi Coding Agent CLI - Professional AI coding assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "piclaw": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/main.js",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "lint": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
