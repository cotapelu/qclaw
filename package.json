{
  "name": "pi-sdk-agent",
  "version": "1.0.0",
  "description": "Custom AI agent using pi SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/**/*.ts --fix",
